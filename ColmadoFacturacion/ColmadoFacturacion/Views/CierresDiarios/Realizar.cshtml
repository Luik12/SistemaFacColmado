@{
    ViewData["Title"] = "Realizar Cierre del Día";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h4><i class="fas fa-cash-register me-2 text-success"></i>Cierre del Día</h4>
        <hr />

        @if (ViewBag.YaRealizado == true)
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Ya se realizó el cierre del día <strong>@ViewBag.FechaHoy.ToString("dd/MM/yyyy")</strong>.
                <a asp-action="Index" class="btn btn-sm btn-outline-warning ms-2">Ver cierres</a>
            </div>
        }
        else
        {
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted mb-3">Resumen del día @ViewBag.FechaHoy.ToString("dd/MM/yyyy")</h6>
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="fs-3 fw-bold text-success">@ViewBag.CantidadVentas</div>
                            <small class="text-muted">Ventas registradas</small>
                        </div>
                        <div class="col-6">
                            <div class="fs-3 fw-bold text-success">RD$ @ViewBag.TotalVentas.ToString("N2")</div>
                            <small class="text-muted">Total del día</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                Al confirmar, el stock de todos los productos vendidos hoy se descontará automáticamente.
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Realizar" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Observación (opcional)</label>
                            <textarea name="observacion" class="form-control" rows="3"
                                      placeholder="Ej: Día sin novedades..."></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success"
                                    onclick="return confirm('¿Confirmas el cierre del día? Esta acción descontará el stock.')">
                                <i class="fas fa-check-circle me-1"></i>Confirmar Cierre
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>