@model IEnumerable<ColmadoFacturacion.Models.Entities.CierreDiario>
@{
    ViewData["Title"] = "Cierres Diarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-calendar-check me-2 text-success"></i>Cierres Diarios</h4>
    <a asp-action="Realizar" class="btn btn-success">
        <i class="fas fa-cash-register me-1"></i>Realizar Cierre de Hoy
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-success">
                <tr>
                    <th>Fecha</th>
                    <th class="text-center">Cant. Ventas</th>
                    <th class="text-end">Total Ventas</th>
                    <th class="text-end">Total Facturado</th>
                    <th>Realizado por</th>
                    <th>Observación</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><strong>@c.Fecha.ToString("dd/MM/yyyy")</strong></td>
                        <td class="text-center">
                            <span class="badge bg-secondary">@c.CantidadVentas</span>
                        </td>
                        <td class="text-end">RD$ @c.TotalVentas.ToString("N2")</td>
                        <td class="text-end text-success fw-bold">RD$ @c.TotalFacturado.ToString("N2")</td>
                        <td>@c.Usuario?.NombreUsuario</td>
                        <td><small class="text-muted">@(c.Observacion ?? "—")</small></td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            <i class="fas fa-inbox me-2"></i>No hay cierres registrados aún.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>