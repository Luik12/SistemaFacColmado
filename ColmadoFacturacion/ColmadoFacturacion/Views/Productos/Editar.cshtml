@model ColmadoFacturacion.Models.Entities.Producto
@{
    ViewData["Title"] = "Editar Producto";
}

<h4><i class="fas fa-edit me-2 text-primary"></i>Editar Producto</h4>
<hr />

<div class="card shadow-sm" style="max-width:650px">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            <input asp-for="ProductoID" type="hidden" />
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Codigo" class="form-label">Código *</label>
                    <input asp-for="Codigo" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label">Nombre *</label>
                    <input asp-for="Nombre" class="form-control" />
                </div>
                <div class="col-md-12">
                    <label asp-for="Descripcion" class="form-label">Descripción</label>
                    <input asp-for="Descripcion" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoriaID" class="form-label">Categoría *</label>
                    <select asp-for="CategoriaID" asp-items="ViewBag.Categorias" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="ProveedorID" class="form-label">Proveedor</label>
                    <select asp-for="ProveedorID" asp-items="ViewBag.Proveedores" class="form-select">
                        <option value="">-- Ninguno --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="PrecioCompra" class="form-label">Precio Compra</label>
                    <div class="input-group">
                        <span class="input-group-text">RD$</span>
                        <input asp-for="PrecioCompra" class="form-control" type="number" step="0.01" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label asp-for="PrecioVenta" class="form-label">Precio Venta</label>
                    <div class="input-group">
                        <span class="input-group-text">RD$</span>
                        <input asp-for="PrecioVenta" class="form-control" type="number" step="0.01" />
                    </div>
                </div>
                <div class="col-md-2">
                    <label asp-for="Stock" class="form-label">Stock</label>
                    <input asp-for="Stock" class="form-control" type="number" />
                </div>
                <div class="col-md-2">
                    <label asp-for="StockMinimo" class="form-label">Mínimo</label>
                    <input asp-for="StockMinimo" class="form-control" type="number" />
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Actualizar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>