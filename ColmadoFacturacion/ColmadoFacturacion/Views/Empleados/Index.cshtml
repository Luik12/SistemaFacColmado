@model IEnumerable<ColmadoFacturacion.Models.Entities.Empleado>
@{
    ViewData["Title"] = "Empleados";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-id-badge me-2 text-success"></i>Empleados</h4>
    <a asp-action="Crear" class="btn btn-success"><i class="fas fa-plus me-1"></i>Nuevo Empleado</a>
</div>
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-success">
                <tr><th>Nombre</th><th>Cédula</th><th>Cargo</th><th>Teléfono</th><th>Ingreso</th><th class="text-center">Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Nombre</td>
                        <td>@e.Cedula</td>
                        <td>@e.Cargo</td>
                        <td>@e.Telefono</td>
                        <td>@e.FechaIngreso.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <a asp-action="Editar" asp-route-id="@e.EmpleadoID" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No hay empleados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>