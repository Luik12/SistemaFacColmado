@model ColmadoFacturacion.Models.Entities.Empleado
@{
    ViewData["Title"] = "Nuevo Empleado";
}

<h4><i class="fas fa-user-tie me-2 text-success"></i>Nuevo Empleado</h4>
<hr />
<div class="card shadow-sm" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Nombre" class="form-label">Nombre completo *</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Cedula" class="form-label">Cédula *</label>
                    <input asp-for="Cedula" class="form-control" placeholder="000-0000000-0" />
                    <span asp-validation-for="Cedula" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Cargo" class="form-label">Cargo *</label>
                    <input asp-for="Cargo" class="form-control" placeholder="Cajero, Almacenista..." />
                    <span asp-validation-for="Cargo" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label">Teléfono</label>
                    <input asp-for="Telefono" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="FechaIngreso" class="form-label">Fecha de Ingreso</label>
                    <input asp-for="FechaIngreso" class="form-control" type="date" />
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-1"></i>Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>