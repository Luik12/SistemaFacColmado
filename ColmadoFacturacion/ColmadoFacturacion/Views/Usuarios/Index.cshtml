@model IEnumerable<ColmadoFacturacion.Models.Entities.Usuario>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-users-cog me-2 text-success"></i>Gestión de Usuarios</h4>
    <a asp-action="Crear" class="btn btn-success">
        <i class="fas fa-user-plus me-1"></i>Nuevo Usuario
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-success">
                <tr>
                    <th>Usuario</th>
                    <th>Email</th>
                    <th>Rol</th>
                    <th class="text-center">Estado</th>
                    <th>Fecha Creación</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr class="@(!u.Activo ? "opacity-50" : "")">
                        <td><i class="fas fa-user me-2 text-muted"></i>@u.NombreUsuario</td>
                        <td>@u.Email</td>
                        <td>
                            <span class="badge @(u.Rol?.Nombre == "Administrador" ? "bg-danger" : u.Rol?.Nombre == "Supervisor" ? "bg-warning text-dark" : "bg-secondary")">
                                @u.Rol?.Nombre
                            </span>
                        </td>
                        <td class="text-center">
                            @if (u.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {

                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </td>
                        <td>@u.FechaCreacion.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <a asp-action="Editar" asp-route-id="@u.UsuarioID"
                                   class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-warning me-1"
                                    title="Cambiar contraseña"
                                    onclick="abrirCambioPassword(@u.UsuarioID, '@u.NombreUsuario')">
                                <i class="fas fa-key"></i>
                            </button>
                            @if (u.Activo)
                            {
                                <a asp-action="Desactivar" asp-route-id="@u.UsuarioID"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('¿Desactivar este usuario?')" title="Desactivar">
                                    <i class="fas fa-ban"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal cambio de contraseña -->
<div class="modal fade" id="modalPassword" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h6 class="modal-title"><i class="fas fa-key me-2"></i>Cambiar Contraseña</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CambiarPassword" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="modalUsuarioID" />
                    <p class="small text-muted">Usuario: <strong id="modalUsuarioNombre"></strong></p>
                    <label class="form-label small">Nueva contraseña</label>
                    <input type="password" name="NuevaPassword" class="form-control"
                           placeholder="Mínimo 6 caracteres" required minlength="6" />
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-warning btn-sm">Cambiar</button>
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function abrirCambioPassword(id, nombre) {
            document.getElementById('modalUsuarioID').value = id;
            document.getElementById('modalUsuarioNombre').innerText = nombre;
            new bootstrap.Modal(document.getElementById('modalPassword')).show();
        }
    </script>
}