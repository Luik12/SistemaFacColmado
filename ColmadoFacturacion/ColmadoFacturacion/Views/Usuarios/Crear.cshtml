@{
    ViewData["Title"] = "Nuevo Usuario";
}

<h4><i class="fas fa-user-plus me-2 text-success"></i>Nuevo Usuario</h4>
<hr />
<div class="card shadow-sm" style="max-width:480px">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            <div class="mb-3">
                <label class="form-label">Nombre de usuario *</label>
                <input name="NombreUsuario" class="form-control" required placeholder="ej: cajero01" />
            </div>
            <div class="mb-3">
                <label class="form-label">Email *</label>
                <input name="Email" type="email" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña *</label>
                <input name="Password" type="password" class="form-control" required minlength="6" />
                <div class="form-text">Mínimo 6 caracteres.</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Rol *</label>
                <select name="RolID" asp-items="ViewBag.Roles" class="form-select">
                    <option value="">-- Selecciona un rol --</option>
                </select>
            </div>
            @Html.ValidationSummary(false, "", new { @class = "text-danger small" })
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-1"></i>Crear Usuario
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>