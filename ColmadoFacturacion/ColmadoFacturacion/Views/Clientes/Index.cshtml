@model IEnumerable<ColmadoFacturacion.Models.Entities.Cliente>
@{
    ViewData["Title"] = "Clientes";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-users me-2 text-success"></i>Clientes</h4>
    <a asp-action="Crear" class="btn btn-success"><i class="fas fa-plus me-1"></i>Nuevo Cliente</a>
</div>
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-success">
                <tr><th>Nombre</th><th>Cédula/RNC</th><th>Teléfono</th><th>Tipo</th><th class="text-center">Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Nombre</td>
                        <td>@(c.EsEmpresa? c.RNC: c.Cedula)</td>
                        <td>@c.Telefono</td>
                        <td><span class="badge @(c.EsEmpresa ? "bg-primary" : "bg-secondary")">@(c.EsEmpresa ? "Empresa" : "Persona")</span></td>
                        <td class="text-center">
                            <a asp-action="Editar" asp-route-id="@c.ClienteID" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No hay clientes.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>