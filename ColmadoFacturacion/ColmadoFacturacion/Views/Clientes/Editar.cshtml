@model ColmadoFacturacion.Models.Entities.Cliente
@{
    ViewData["Title"] = "Editar Cliente";
}

<h4><i class="fas fa-user-edit me-2 text-primary"></i>Editar Cliente</h4>
<hr />
<div class="card shadow-sm" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Editar" method="post">
            <input asp-for="ClienteID" type="hidden" />
            <input asp-for="FechaRegistro" type="hidden" />
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Nombre" class="form-label">Nombre *</label>
                    <input asp-for="Nombre" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Cedula" class="form-label">Cédula</label>
                    <input asp-for="Cedula" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="RNC" class="form-label">RNC</label>
                    <input asp-for="RNC" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label">Teléfono</label>
                    <input asp-for="Telefono" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                </div>
                <div class="col-12">
                    <label asp-for="Direccion" class="form-label">Dirección</label>
                    <input asp-for="Direccion" class="form-control" />
                </div>
                <div class="col-12">
                    <div class="form-check form-switch">
                        <input asp-for="EsEmpresa" class="form-check-input" type="checkbox" />
                        <label asp-for="EsEmpresa" class="form-check-label fw-bold text-primary">Es empresa</label>
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>Actualizar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>