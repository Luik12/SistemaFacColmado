@model IEnumerable<ColmadoFacturacion.Models.Entities.Factura>
@{
    ViewData["Title"] = "Facturas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-file-invoice-dollar me-2 text-success"></i>Facturas Emitidas</h4>
</div>
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-success">
                <tr>
                    <th>No. Factura</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th class="text-end">Subtotal</th>
                    <th class="text-end">ITBIS 18%</th>
                    <th class="text-end">Total</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Ver</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td><strong>@f.NumeroFactura</strong></td>
                        <td>@f.FechaEmision.ToString("dd/MM/yyyy")</td>
                        <td>@f.Cliente?.Nombre</td>
                        <td class="text-end">RD$ @f.Subtotal.ToString("N2")</td>
                        <td class="text-end">RD$ @f.ITBIS.ToString("N2")</td>
                        <td class="text-end fw-bold">RD$ @f.Total.ToString("N2")</td>
                        <td class="text-center">
                            @if (f.Anulada)
                            {
                                <span class="badge bg-danger">Anulada</span>
                            }
                            else
                            {

                                <span class="badge bg-success">Vigente</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Detalle" asp-route-id="@f.FacturaID"
                                   class="btn btn-sm btn-outline-info">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No hay facturas emitidas aún.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>