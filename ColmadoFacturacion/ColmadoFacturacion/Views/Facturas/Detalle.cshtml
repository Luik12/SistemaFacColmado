@model ColmadoFacturacion.Models.Entities.Factura
@{ ViewData["Title"] = "Detalle de Factura"; }

<div class="row justify-content-center">
    <div class="col-md-8">

        <!-- Botones de acción -->
        <div class="d-flex justify-content-between mb-3">
            <a asp-action="Index" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left me-1"></i>Volver
            </a>
            <button onclick="window.print()" class="btn btn-success btn-sm">
                <i class="fas fa-print me-1"></i>Imprimir
            </button>
        </div>

        <!-- Factura -->
        <div class="card shadow" id="facturaImprimir">
            <div class="card-body p-4">

                <!-- Encabezado -->
                <div class="row mb-4">
                    <div class="col-6">
                        <h4 class="text-success fw-bold"><i class="fas fa-store me-2"></i>Mi Colmado</h4>
                        <small class="text-muted">Sistema de Facturación</small>
                    </div>
                    <div class="col-6 text-end">
                        <h5 class="fw-bold">FACTURA</h5>
                        <span class="badge bg-success fs-6">@Model.NumeroFactura</span><br/>
                        @if (Model.Anulada)
                        {
                            <span class="badge bg-danger mt-1">ANULADA</span>
                        }
                    </div>
                </div>

                <hr/>

                <!-- Datos de factura y cliente -->
                <div class="row mb-4">
                    <div class="col-6">
                        <p class="mb-1"><strong>Cliente:</strong> @Model.Cliente?.Nombre</p>
                        <p class="mb-1"><strong>RNC/Cédula:</strong>
                            @(Model.Cliente?.EsEmpresa == true ? Model.Cliente?.RNC : Model.Cliente?.Cedula ?? "—")
                        </p>
                        <p class="mb-1"><strong>Teléfono:</strong> @(Model.Cliente?.Telefono ?? "—")</p>
                        <p class="mb-0"><strong>Dirección:</strong> @(Model.Cliente?.Direccion ?? "—")</p>
                    </div>
                    <div class="col-6 text-end">
                        <p class="mb-1"><strong>Fecha:</strong> @Model.FechaEmision.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="mb-1"><strong>Venta #:</strong> @Model.VentaID</p>
                        <p class="mb-0"><strong>Atendido por:</strong> @Model.Venta?.Empleado?.Nombre</p>
                    </div>
                </div>

                <!-- Detalle de productos -->
                <table class="table table-sm table-bordered">
                    <thead class="table-success">
                        <tr>
                            <th>#</th>
                            <th>Producto</th>
                            <th class="text-center">Cant.</th>
                            <th class="text-end">Precio Unit.</th>
                            <th class="text-end">Descuento</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int linea = 1; }
                        @foreach (var d in Model.Venta?.Detalles ?? new List<ColmadoFacturacion.Models.Entities.DetalleVenta>())
                        {
                            <tr>
                                <td>@linea</td>
                                <td>@d.Producto?.Nombre</td>
                                <td class="text-center">@d.Cantidad</td>
                                <td class="text-end">RD$ @d.PrecioUnitario.ToString("N2")</td>
                                <td class="text-end">RD$ @d.Descuento.ToString("N2")</td>
                                <td class="text-end">RD$ @d.Subtotal.ToString("N2")</td>
                            </tr>
                            linea++;
                        }
                    </tbody>
                </table>

                <!-- Totales -->
                <div class="row justify-content-end">
                    <div class="col-md-4">
                        <table class="table table-sm mb-0">
                            <tr>
                                <td class="text-muted">Subtotal:</td>
                                <td class="text-end">RD$ @Model.Subtotal.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Descuento:</td>
                                <td class="text-end">RD$ @Model.Descuento.ToString("N2")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">ITBIS (18%):</td>
                                <td class="text-end">RD$ @Model.ITBIS.ToString("N2")</td>
                            </tr>
                            <tr class="table-success fw-bold">
                                <td>TOTAL:</td>
                                <td class="text-end fs-5">RD$ @Model.Total.ToString("N2")</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Observación -->
                @if (!string.IsNullOrEmpty(Model.Observacion))
                {
                    <hr/>
                    <p class="text-muted small"><strong>Observación:</strong> @Model.Observacion</p>
                }

                <hr/>
                <p class="text-center text-muted small mb-0">
                    ¡Gracias por su compra! — Documento generado el @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                </p>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<style>
    @@media print {
        nav, .btn, .d-flex { display: none !important; }
        .card { border: none !important; box-shadow: none !important; }
    }
</style>
}