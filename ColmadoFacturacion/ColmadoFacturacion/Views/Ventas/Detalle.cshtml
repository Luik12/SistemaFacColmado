@model ColmadoFacturacion.Models.Entities.Venta
@{
    ViewData["Title"] = "Detalle de Venta";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="d-flex justify-content-between mb-3">
            <a asp-action="Index" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left me-1"></i>Volver
            </a>
            @if (Model.Facturada && Model.Factura != null)
            {
                <a asp-controller="Facturas" asp-action="Detalle" asp-route-id="@Model.Factura.FacturaID"
                       class="btn btn-success btn-sm">
                    <i class="fas fa-file-invoice me-1"></i>Ver Factura
                </a>
            }
        </div>

        <div class="card shadow">
            <div class="card-header bg-success text-white d-flex justify-content-between">
                <span><i class="fas fa-receipt me-2"></i>Venta #@Model.VentaID</span>
                <span>@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="card-body">

                <div class="row mb-3">
                    <div class="col-6">
                        <p class="mb-1"><strong>Cliente:</strong> @(Model.Cliente?.Nombre ?? "Cliente Mostrador")</p>
                        <p class="mb-0"><strong>Empleado:</strong> @Model.Empleado?.Nombre</p>
                    </div>
                    <div class="col-6 text-end">
                        <span class="badge @(Model.Anulada ? "bg-danger" : "bg-success") fs-6">
                            @(Model.Anulada ? "Anulada" : "Activa")
                        </span><br />
                        @if (Model.Facturada)
                        {
                            <span class="badge bg-primary mt-1">Facturada</span>
                        }
                    </div>
                </div>

                <table class="table table-sm table-bordered">
                    <thead class="table-success">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Cant.</th>
                            <th class="text-end">Precio</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Detalles)
                        {
                            <tr>
                                <td>@d.Producto?.Nombre</td>
                                <td class="text-center">@d.Cantidad</td>
                                <td class="text-end">RD$ @d.PrecioUnitario.ToString("N2")</td>
                                <td class="text-end">RD$ @d.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="row justify-content-end">
                    <div class="col-md-4">
                        <table class="table table-sm">
                            <tr><td class="text-muted">Subtotal:</td><td class="text-end">RD$ @Model.Subtotal.ToString("N2")</td></tr>
                            <tr><td class="text-muted">ITBIS:</td><td class="text-end">RD$ @Model.ITBIS.ToString("N2")</td></tr>
                            <tr class="fw-bold table-success">
                                <td>Total:</td>
                                <td class="text-end">RD$ @Model.Total.ToString("N2")</td>
                            </tr>
                        </table>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Observacion))
                {
                    <p class="text-muted small"><strong>Obs:</strong> @Model.Observacion</p>
                }
            </div>
        </div>
    </div>
</div>