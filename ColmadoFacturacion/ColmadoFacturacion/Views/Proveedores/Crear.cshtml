@model ColmadoFacturacion.Models.Entities.Proveedor
@{
    ViewData["Title"] = "Nuevo Proveedor";
}

<h4><i class="fas fa-truck me-2 text-success"></i>Nuevo Proveedor</h4>
<hr />
<div class="card shadow-sm" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Nombre" class="form-label">Nombre *</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="RNC" class="form-label">RNC</label>
                    <input asp-for="RNC" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Contacto" class="form-label">Persona de contacto</label>
                    <input asp-for="Contacto" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Telefono" class="form-label">Teléfono</label>
                    <input asp-for="Telefono" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                </div>
                <div class="col-12">
                    <label asp-for="Direccion" class="form-label">Dirección</label>
                    <input asp-for="Direccion" class="form-control" />
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-1"></i>Guardar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>